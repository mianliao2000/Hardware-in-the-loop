# OpenAI-compatible chat-completions endpoint.
# The GUI backend reads the generic LLM_* variables.
LLM_API_BASE_URL=https://api.minimax.io/v1
# Optional: set this only when the provider needs a nonstandard full chat endpoint.
# LLM_API_ENDPOINT=https://api.minimax.io/v1/chat/completions
LLM_API_KEY=your_minimax_api_key_here
LLM_MODEL=MiniMax-M3
LLM_TIMEOUT_S=30
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=700

# Provider-specific variables for Minimax.
MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_BASE_URL=https://api.minimax.io/v1
# MINIMAX_CHAT_ENDPOINT=https://api.minimax.io/v1/chat/completions
MINIMAX_MODEL=MiniMax-M3
