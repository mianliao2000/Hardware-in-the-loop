# OMICRON Bode 100 SCPI runner settings.
BODE100_SERIAL=your_bode100_serial_here
BODE100_HOST=127.0.0.1
BODE100_PORT=5025

# OpenAI-compatible fallback settings.
LLM_API_BASE_URL=https://openrouter.ai/api/v1
LLM_API_KEY=your_openrouter_api_key_here
LLM_MODEL=google/gemini-3.5-flash
LLM_TIMEOUT_S=30
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=700

# Provider-specific settings. The GUI model selector routes to these blocks.
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_CHAT_ENDPOINT=https://openrouter.ai/api/v1/chat/completions
OPENROUTER_MODEL=google/gemini-3.5-flash

# Optional web-search enrichment for AI Copilot.
# When enabled, gui/server.py searches only for questions that look like they
# need current/external information, then passes short search results to the LLM.
WEB_SEARCH_ENABLED=true
WEB_SEARCH_MAX_RESULTS=4
WEB_SEARCH_TIMEOUT_S=6
# Optional: set this for better web search results. Without it, the backend
# falls back to DuckDuckGo Instant Answer, which is free but less complete.
# TAVILY_API_KEY=your_tavily_api_key_here
# TAVILY_SEARCH_DEPTH=basic

MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_BASE_URL=https://api.minimax.io/v1
MINIMAX_CHAT_ENDPOINT=https://api.minimax.io/v1/chat/completions
MINIMAX_MODEL=MiniMax-M3

# Optional CPU-only Safe SAC training controls.
DRL_CPU_THREADS=8
DRL_SURROGATE_EPOCHS=300
DRL_SAC_STEPS=1000000
DRL_EVAL_EPISODES=10000
